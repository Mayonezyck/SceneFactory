    <child link="front_left_steer_link" />
    <axis xyz="0 0 1" />
    <limit lower="-0.558505361" upper="0.558505361" effort="1200" velocity="4" />
    <dynamics damping="25" friction="1" />
  </joint><link name="front_left_wheel_link">
