<?xml version="1.0"?>
<robot name="student_fwd_vehicle">
  <material name="wizard_chassis_blue">
    <color rgba="0.2784314 0.64705884 1 1" />
  </material><material name="hidden_helper">
    <color rgba="0 0 0 0" />
  </material><material name="wheel_black">
    <color rgba="0.06 0.06 0.06 1" />
  </material><link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="4 2 1" />
      </geometry><material name="wizard_chassis_blue" />
    </visual><collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="4 2 1" />
      </geometry>
    </collision><inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="1800" />
      <inertia ixx="750" ixy="0" ixz="0" iyy="2550" iyz="0" izz="3000" />
    </inertial>
  </link><link name="front_left_suspension_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.08 0.05 0.175" />
      </geometry><material name="hidden_helper" />
    </visual><inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="6" />
      <inertia ixx="0.0165625" ixy="0" ixz="0" iyy="0.0185125" iyz="0" izz="0.00445" />
    </inertial>
  </link><joint name="front_left_suspension_joint" type="prismatic">
    <origin xyz="1.3 1 -0.325" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="front_left_suspension_link" />
    <axis xyz="0 0 1" />
    <limit lower="-0.175" upper="0.175" effort="15000" velocity="3" />
    <dynamics damping="2200" friction="120" />
  </joint><link name="front_left_steer_link">
